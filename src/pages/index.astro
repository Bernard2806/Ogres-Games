---
// index.astro
import '../styles/global.css';
import CrtOverlay from '../components/CrtOverlay.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Projects from '../components/Projects.astro';
import DiscordQuest from '../components/DiscordQuest.astro';
import Servers from '../components/Servers.astro';
import Team from '../components/Team.astro';
import Donations from '../components/Donations.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Optimization -->
    <title>Ogres Games | Comunidad Gamer & Servidores Retro</title>
    <meta name="description" content="Comunidad gamer oficial de Ogres Games. Únete a nuestro servidor de Minecraft Cobbleverse y revive los clásicos en nuestro servidor de Counter-Strike 1.6." />
    <link rel="canonical" href="https://ogresblood.games/" />
    <meta name="robots" content="index, follow" />
    
    <!-- Social Meta (OpenGraph / Twitter) -->
    <meta property="og:title" content="Ogres Games | Comunidad Gamer & Servidores Retro" />
    <meta property="og:description" content="Comunidad de videojuegos indie con espíritu retro de los 80/90 y servidores comunitarios de Minecraft Cobbleverse y Counter-Strike 1.6." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://ogresblood.games/" />
    <meta property="og:image" content="https://ogresblood.games/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:locale" content="es_ES" />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Ogres Games | Comunidad Gamer & Servidores Retro" />
    <meta name="twitter:description" content="Comunidad de videojuegos indie con espíritu retro de los 80/90 y servidores comunitarios de Minecraft Cobbleverse y Counter-Strike 1.6." />
    <meta name="twitter:image" content="https://ogresblood.games/og-image.png" />
    
    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- JSON-LD Structured Data for Google -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "WebSite",
            "@id": "https://ogresblood.games/#website",
            "url": "https://ogresblood.games/",
            "name": "Ogres Games",
            "description": "Comunidad gamer oficial de Ogres Games con servidores retro y activos de Minecraft Cobbleverse y Counter-Strike 1.6.",
            "publisher": {
              "@id": "https://ogresblood.games/#organization"
            },
            "inLanguage": "es"
          },
          {
            "@type": "Organization",
            "@id": "https://ogresblood.games/#organization",
            "name": "Ogres Games",
            "url": "https://ogresblood.games/",
            "logo": {
              "@type": "ImageObject",
              "@id": "https://ogresblood.games/#logo",
              "url": "https://ogresblood.games/favicon.png",
              "caption": "Ogres Games Logo"
            },
            "image": {
              "@id": "https://ogresblood.games/#logo"
            },
            "sameAs": [
              "https://discord.gg/ogresgames"
            ]
          }
        ]
      }
    </script>
  </head>
  <body>
    <!-- CRT monitor screen scanlines & flicker overlay effect -->
    <CrtOverlay />

    <!-- Navigation Header -->
    <Header />

    <!-- Main Content Area -->
    <main>
      <!-- Hero Boot Screen -->
      <Hero />

      <!-- Active Discord Mission Board -->
      <DiscordQuest />

      <!-- Games Showcase -->
      <Projects />

      <!-- Server Center -->
      <Servers />

      <!-- Team RPG Profile selector -->
      <Team />

      <!-- Donation Board -->
      <Donations />
    </main>

    <!-- Retro Console Controller Footer -->
    <Footer />
  </body>
</html>

<style>
  /* Main wrapper overrides if needed */
  main {
    position: relative;
    z-index: 10;
  }
</style>
