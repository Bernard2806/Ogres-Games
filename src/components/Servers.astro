---
// Servers.astro
import serversData from '../data/servers.json';
import pokemonLogo from '../assets/images/sv-pokemon.png';
import counterLogo from '../assets/images/sv-counter.png';

const logoMap = {
  minecraft_cobbleverse: pokemonLogo,
  cs_16: counterLogo
};
---

<section id="servers" class="servers-section">
  <div class="container">
    <h2 class="section-title">SERVIDORES OFICIALES</h2>
    <p class="section-desc">Únete a nuestra comunidad gamer. Servidores dedicados con soporte 24/7 y contenido personalizado.</p>
    
    <div class="servers-dashboard">
      
      <!-- Servers grid -->
      <div class="servers-list">
        {serversData.map((server) => {
          const logo = logoMap[server.id as keyof typeof logoMap];
          const isOnline = server.status.toLowerCase() === 'online' || server.status.toLowerCase() === 'active';
          const isUpcoming = server.status.toLowerCase() === 'próximamente' || server.status.toLowerCase() === 'mantenimiento';
          
          return (
            <div class="server-node pixel-border" data-server-id={server.id} data-server-ip={server.ip}>
              <div class="server-card-header">
                {logo && (
                  <div class="server-logo-wrapper">
                    <img src={logo.src} alt={`${server.name} Logo`} class="server-logo-img" />
                  </div>
                )}
                <div class="server-title-meta">
                  <div class="server-node-header">
                    <span class="game-tag tag tag-cyan">{server.game}</span>
                    <div class="status-indicator">
                      <span class={`status-led ${isOnline ? 'led-online' : isUpcoming ? 'led-upcoming' : 'led-offline'}`}></span>
                      <span class={`status-text terminal-font ${isOnline ? 'text-online' : isUpcoming ? 'text-upcoming' : 'text-offline'}`} id={`status-text-${server.id}`}>{server.status}</span>
                    </div>
                  </div>
                  <h3 class="server-name arcade-font">{server.name}</h3>
                </div>
              </div>
              
              <p class="server-desc">{server.description}</p>
              
              {server.id === 'minecraft_cobbleverse' && (
                <div class="system-req-box terminal-font">
                  <div class="req-header arcade-font">💻 ¡OPTIMIZADO PARA NETBOOK DEL GOBIERNO!</div>
                  <div class="req-specs">
                    <div class="spec-line"><span class="label">Procesador:</span> <span class="value">Intel Celeron N5100</span></div>
                    <div class="spec-line"><span class="label">Memoria RAM:</span> <span class="value">4 GB (Soldada, no exp.)</span></div>
                    <div class="spec-line"><span class="label">Almacenamiento:</span> <span class="value">128 GB SSD</span></div>
                    <div class="spec-line spec-fps"><span class="label">Rendimiento:</span> <span class="value highlight-fps">10-30 FPS (Ajustes Mínimos)</span></div>
                  </div>
                </div>
              )}
              
              <div class="server-meta-grid terminal-font">
                <div class="meta-item">
                  <span class="label">VERSION:</span>
                  <span class="value" id={`version-${server.id}`}>{server.version}</span>
                </div>
                <div class="meta-item">
                  <span class="label">PLAYERS:</span>
                  <span class="value" id={`players-${server.id}`}>{server.players.online} / {server.players.max}</span>
                </div>
                <div class="meta-item-full">
                  <span class="label">DIRECCIÓN IP:</span>
                  <span class="value highlight-ip clickable-ip" data-ip={server.ip} title="Click para copiar IP">
                    {server.ip}
                    <span class="copy-hint arcade-font">[COPIAR]</span>
                  </span>
                </div>
              </div>
              
              <div class="server-key-features">
                <h4 class="features-title arcade-font">CARACTERÍSTICAS:</h4>
                <ul class="features-list">
                  {server.features.map(feat => (
                    <li class="feature-item">⭐ {feat}</li>
                  ))}
                </ul>
              </div>
              
              {server.id === 'minecraft_cobbleverse' && (
                <div class="server-actions">
                  <button class="pixel-button pixel-button-green" id="open-modpack-modal-btn">
                    📦 DESCARGAR MODPACK
                  </button>
                </div>
              )}
            </div>
          );
        })}
      </div>
      
      <div class="clipboard-toast arcade-font" id="clipboard-toast">
        ¡IP COPIADA AL PORTAPAPELES!
      </div>
      
      <!-- Modpack Download Modal -->
      <div class="download-modal-backdrop" id="download-modal">
        <div class="download-modal-box pixel-border">
          <button class="modal-close-btn arcade-font" id="close-modal-btn" aria-label="Cerrar">X</button>
          
          <div class="modal-header">
            <span class="lock-icon">🔒</span>
            <h3 class="modal-title arcade-font glow-text-cyan">DESCARGAR MODPACK</h3>
          </div>
          
          <p class="modal-desc">
            Selecciona tu servidor de descarga preferido para obtener el modpack de **Ogres Cobbleverse**.
          </p>
          
          <!-- Contraseña Súper Obvia -->
          <div class="password-alert-box">
            <div class="alert-title arcade-font blinking-text">⚠️ ¡ATENCIÓN: ARCHIVO COMPRIMIDO! ⚠️</div>
            <p class="alert-text">El archivo descargado requiere una contraseña para extraerse:</p>
            <div class="password-display-wrapper">
              <span class="password-label terminal-font">CONTRASEÑA:</span>
              <span class="password-value arcade-font" id="password-value">2026</span>
              <button class="copy-pass-btn terminal-font" id="copy-pass-btn">COPIAR</button>
            </div>
            <div class="copy-success-hint terminal-font" id="copy-pass-toast">¡Contraseña copiada al portapapeles!</div>
          </div>
          
          <!-- Enlaces de Descarga -->
          <div class="download-options">
            <!-- MediaFire -->
            <a href="https://www.mediafire.com" target="_blank" rel="noopener noreferrer" class="download-opt-link mediafire-btn">
              <svg class="provider-logo-svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
                <path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/>
              </svg>
              <span class="host-name arcade-font">MEDIAFIRE</span>
            </a>
            
            <!-- Mega -->
            <a href="https://mega.nz" target="_blank" rel="noopener noreferrer" class="download-opt-link mega-btn">
              <svg class="provider-logo-svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
                <circle cx="12" cy="12" r="10" fill="currentColor"/>
                <path d="M7 16V9.5L10 12l3-2.5V16h2V8h-2l-3 2.5L7 8H5v8h2z" fill="#0d0a1c"/>
              </svg>
              <span class="host-name arcade-font">MEGA</span>
            </a>
            
            <!-- WorkUpload -->
            <a href="https://workupload.com" target="_blank" rel="noopener noreferrer" class="download-opt-link workupload-btn">
              <svg class="provider-logo-svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
                <circle cx="12" cy="12" r="10" fill="currentColor"/>
                <path d="M12 7l-4 4h3v5h2v-5h3l-4-4z" fill="#0d0a1c"/>
              </svg>
              <span class="host-name arcade-font">WORKUPLOAD</span>
            </a>
          </div>
          
          <!-- Soporte Discord y Botón de Cierre -->
          <div class="modal-footer-help">
            <p class="help-text">¿Necesitas ayuda con la instalación o tienes dudas?</p>
            <a href="https://discord.gg/ogresgames" target="_blank" rel="noopener noreferrer" class="pixel-button pixel-button-purple discord-help-btn">
              💬 PEDIR AYUDA EN DISCORD
            </a>
            
            <button class="pixel-button pixel-button-pink close-modal-footer-btn" id="close-modal-footer-btn">
              ❌ CERRAR VENTANA
            </button>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>

<script>
  // Clipboard copying mechanism
  const copyButtons = document.querySelectorAll('.copy-ip-btn');
  const clickableIps = document.querySelectorAll('.clickable-ip');
  const toast = document.getElementById('clipboard-toast');

  function copyIpToClipboard(ipText: string) {
    navigator.clipboard.writeText(ipText).then(() => {
      if (toast) {
        toast.classList.add('show');
        setTimeout(() => {
          toast.classList.remove('show');
        }, 2500);
      }
    }).catch(err => {
      console.error('Failed to copy text: ', err);
    });
  }

  copyButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const ip = btn.getAttribute('data-ip');
      if (ip) copyIpToClipboard(ip);
    });
  });

  clickableIps.forEach(ipSpan => {
    ipSpan.addEventListener('click', () => {
      const ip = ipSpan.getAttribute('data-ip');
      if (ip) copyIpToClipboard(ip);
    });
  });

  // Real-time API query for Minecraft server
  async function fetchMinecraftStatus() {
    const mcServerId = 'minecraft_cobbleverse';
    const mcIp = 'pokemon.ogresblood.games';
    const playersVal = document.getElementById(`players-${mcServerId}`);
    const statusTextVal = document.getElementById(`status-text-${mcServerId}`);
    const ledIndicator = document.querySelector(`[data-server-id="${mcServerId}"] .status-led`);
    
    if (!playersVal || !statusTextVal || !ledIndicator) return;
    
    try {
      const response = await fetch(`https://api.mcsrvstat.us/3/${mcIp}`);
      if (!response.ok) throw new Error('API network response was not ok');
      const data = await response.json();
      
      if (data.online) {
        // Update players
        playersVal.textContent = `${data.players.online} / ${data.players.max}`;
        
        // Update status text
        statusTextVal.textContent = 'ONLINE';
        statusTextVal.className = 'status-text terminal-font text-online';
        
        // Update status LED
        ledIndicator.className = 'status-led led-online';
      } else {
        // Server is offline
        playersVal.textContent = `0 / --`;
        statusTextVal.textContent = 'OFFLINE';
        statusTextVal.className = 'status-text terminal-font text-offline';
        ledIndicator.className = 'status-led led-offline';
      }
    } catch (error) {
      console.error('Error fetching Minecraft server status:', error);
      // Keep static defaults on failure
    }
  }

  // Execute on load
  fetchMinecraftStatus();
  // Refresh every 60 seconds
  setInterval(fetchMinecraftStatus, 60000);

  // Modal open/close controls
  const openModalBtn = document.getElementById('open-modpack-modal-btn');
  const closeModalBtn = document.getElementById('close-modal-btn');
  const modalBackdrop = document.getElementById('download-modal');
  const copyPassBtn = document.getElementById('copy-pass-btn');
  const passToast = document.getElementById('copy-pass-toast');

  if (openModalBtn && modalBackdrop) {
    openModalBtn.addEventListener('click', () => {
      modalBackdrop.classList.add('show');
      document.body.style.overflow = 'hidden'; // Block background scrolling
    });
  }

  if (closeModalBtn && modalBackdrop) {
    closeModalBtn.addEventListener('click', () => {
      modalBackdrop.classList.remove('show');
      document.body.style.overflow = ''; // Allow scrolling
    });
    
    // Close modal when clicking outside box
    modalBackdrop.addEventListener('click', (e) => {
      if (e.target === modalBackdrop) {
        modalBackdrop.classList.remove('show');
        document.body.style.overflow = '';
      }
    });
  }

  if (copyPassBtn && passToast) {
    copyPassBtn.addEventListener('click', () => {
      navigator.clipboard.writeText('2026').then(() => {
        passToast.classList.add('show');
        setTimeout(() => {
          passToast.classList.remove('show');
        }, 2000);
      }).catch(err => {
        console.error('Failed to copy password: ', err);
      });
    });
  }
</script>

<style>
  .servers-section {
    padding: 100px 0;
    border-top: 3px solid #141026;
    background-color: #07050e;
  }

  .servers-dashboard {
    display: flex;
    flex-direction: column;
    gap: 40px;
    margin-top: 40px;
    position: relative;
  }

  .servers-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
    width: 100%;
  }

  @media (max-width: 992px) {
    .servers-list {
      grid-template-columns: 1fr;
    }
  }

  .server-node {
    background-color: var(--color-panel-bg);
    border-color: #231c3c;
    padding: 30px;
    border-radius: 4px;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .server-node:hover {
    border-color: var(--neon-cyan);
    box-shadow: 0 0 15px var(--neon-cyan-glow);
  }

  .server-card-header {
    display: flex;
    gap: 20px;
    align-items: center;
    margin-bottom: 20px;
  }

  .server-logo-wrapper {
    flex-shrink: 0;
    width: 72px;
    height: 72px;
    background-color: rgba(15, 10, 28, 0.6);
    border: 2px solid #231c3c;
    border-radius: 4px;
    padding: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.5), inset 0 0 5px rgba(0, 240, 255, 0.1);
    transition: all 0.3s ease;
  }

  .server-node:hover .server-logo-wrapper {
    border-color: var(--neon-cyan);
    box-shadow: 0 0 15px var(--neon-cyan-glow);
  }

  .server-logo-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .server-title-meta {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .server-node-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .status-indicator {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .status-led {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .led-online {
    background-color: var(--neon-green);
    box-shadow: 0 0 10px var(--neon-green);
    animation: led-blink 1.5s infinite alternate;
  }

  .led-upcoming {
    background-color: var(--neon-yellow);
    box-shadow: 0 0 10px var(--neon-yellow);
    animation: led-blink 2s infinite alternate;
  }

  .led-offline {
    background-color: #ff0055;
    box-shadow: 0 0 10px #ff0055;
  }

  @keyframes led-blink {
    0% { opacity: 0.6; }
    100% { opacity: 1; }
  }

  .status-text {
    font-size: 1.1rem;
    color: #fff;
  }

  .text-online {
    color: var(--neon-green);
    text-shadow: 0 0 5px var(--neon-green-glow);
  }

  .text-upcoming {
    color: var(--neon-yellow);
    text-shadow: 0 0 5px var(--neon-yellow-glow);
  }

  .text-offline {
    color: #ff0055;
    text-shadow: 0 0 5px rgba(255, 0, 85, 0.5);
  }

  .server-name {
    font-size: 1.2rem;
    color: #fff;
    letter-spacing: 1px;
    margin: 0;
  }

  .server-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 20px;
    line-height: 1.6;
    min-height: 50px; /* Aligns description size */
  }

  /* Hardware requirement box (netbook) */
  .system-req-box {
    margin-bottom: 20px;
    background: rgba(57, 255, 20, 0.03);
    border: 1px dashed var(--neon-green);
    padding: 15px;
    border-radius: 4px;
    box-shadow: inset 0 0 10px rgba(57, 255, 20, 0.05);
  }

  .req-header {
    font-size: 0.65rem;
    color: var(--neon-green);
    margin-bottom: 10px;
    letter-spacing: 0.5px;
    text-shadow: 0 0 5px var(--neon-green-glow);
  }

  .req-specs {
    font-size: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .spec-line {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px dotted rgba(149, 143, 168, 0.15);
    padding-bottom: 2px;
  }

  .spec-line:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .spec-fps {
    margin-top: 4px;
    padding-top: 4px;
    border-top: 1px dashed rgba(57, 255, 20, 0.2);
    border-bottom: none;
  }

  .req-specs .label {
    color: var(--color-text-muted);
  }

  .req-specs .value {
    color: #fff;
  }

  .highlight-fps {
    color: var(--neon-green) !important;
    text-shadow: 0 0 5px var(--neon-green-glow);
    font-weight: bold;
  }

  .server-meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
    background: rgba(0, 0, 0, 0.4);
    padding: 15px;
    border-radius: 4px;
    border: 1px solid #1c1638;
    margin-bottom: 25px;
  }

  .meta-item, .meta-item-full {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .meta-item-full {
    grid-column: span 2;
    border-top: 1px dashed #231c3c;
    padding-top: 12px;
    margin-top: 5px;
  }

  .server-meta-grid .label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .server-meta-grid .value {
    font-size: 1.2rem;
    color: #fff;
  }

  .highlight-ip {
    color: var(--neon-cyan) !important;
    text-shadow: 0 0 5px var(--neon-cyan-glow);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    width: fit-content;
  }

  .clickable-ip {
    cursor: pointer;
    transition: transform 0.1s ease;
  }

  .clickable-ip:hover {
    transform: scale(1.02);
  }

  .copy-hint {
    font-size: 0.55rem;
    color: var(--color-text-muted);
    border: 1px solid var(--color-text-muted);
    padding: 2px 5px;
    margin-left: 5px;
    transition: all 0.15s ease;
  }

  .clickable-ip:hover .copy-hint {
    color: var(--neon-green);
    border-color: var(--neon-green);
    box-shadow: 0 0 5px var(--neon-green-glow);
  }

  /* Features */
  .server-key-features {
    margin-bottom: 25px;
    flex-grow: 1; /* Pushes action buttons to the bottom of the card */
  }

  .features-title {
    font-size: 0.7rem;
    color: #fff;
    margin-bottom: 12px;
  }

  .features-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .feature-item {
    font-size: 0.85rem;
    color: var(--color-text);
  }

  /* Actions */
  .server-actions {
    display: flex;
    gap: 20px;
    margin-top: auto;
  }

  .server-actions .pixel-button {
    flex: 1;
    font-size: 0.75rem;
  }

  /* Toast Notification */
  .clipboard-toast {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%) translateY(50px);
    background: #0f0a1c;
    color: var(--neon-green);
    border: 2px solid var(--neon-green);
    box-shadow: 0 0 15px var(--neon-green-glow);
    padding: 12px 24px;
    font-size: 0.65rem;
    opacity: 0;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    pointer-events: none;
    z-index: 100;
  }

  .clipboard-toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (max-width: 576px) {
    .server-card-header {
      flex-direction: column;
      align-items: flex-start;
    }
    
    .server-logo-wrapper {
      width: 60px;
      height: 60px;
    }

    .server-meta-grid {
      grid-template-columns: 1fr;
    }
    .meta-item-full {
      grid-column: span 1;
    }
    .features-list {
      grid-template-columns: 1fr;
    }
    .server-actions {
      flex-direction: column;
      gap: 15px;
    }
  }

  /* Modal Styles */
  .download-modal-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(5, 3, 10, 0.9);
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: all 0.3s ease;
    backdrop-filter: blur(5px);
  }

  .download-modal-backdrop.show {
    opacity: 1;
    pointer-events: auto;
  }

  .download-modal-box {
    max-width: 480px;
    width: 90%;
    max-height: 90vh; /* Perfect responsiveness: limit height */
    overflow-y: auto;  /* Perfect responsiveness: internal scroll */
    background-color: #0d0a1c;
    border: 4px solid var(--neon-cyan);
    box-shadow: 0 0 30px rgba(0, 240, 255, 0.25), inset 0 0 15px rgba(0, 240, 255, 0.1);
    padding: 35px 25px;
    border-radius: 4px;
    position: relative;
    transform: scale(0.9);
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: flex;
    flex-direction: column;
    gap: 20px;
    box-sizing: border-box;
  }

  /* Custom retro scrollbar inside the modal */
  .download-modal-box::-webkit-scrollbar {
    width: 6px;
  }
  .download-modal-box::-webkit-scrollbar-track {
    background: #0d0a1c;
  }
  .download-modal-box::-webkit-scrollbar-thumb {
    background: var(--neon-cyan);
    border-radius: 2px;
  }

  .download-modal-backdrop.show .download-modal-box {
    transform: scale(1);
  }

  .modal-close-btn {
    position: absolute;
    top: 15px;
    right: 15px;
    background: transparent;
    border: 2px solid var(--neon-pink);
    color: var(--neon-pink);
    font-family: var(--font-arcade);
    font-size: 0.9rem;
    padding: 6px 10px;
    cursor: pointer;
    box-shadow: 0 0 5px var(--neon-pink-glow);
    transition: all 0.15s ease;
    z-index: 10;
  }

  .modal-close-btn:hover {
    background-color: var(--neon-pink);
    color: #07050e;
    box-shadow: 0 0 12px var(--neon-pink);
    transform: scale(1.05);
  }

  .modal-header {
    display: flex;
    align-items: center;
    gap: 12px;
    justify-content: center;
    border-bottom: 2px solid rgba(0, 240, 255, 0.15);
    padding-bottom: 15px;
    margin-top: 10px; /* Space for close X */
  }

  .lock-icon {
