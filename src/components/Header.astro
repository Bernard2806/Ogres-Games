---
// Header.astro
import logoImg from '../assets/images/Logo-OG.png';
---

<header class="retro-header">
  <div class="container header-container">
    <!-- Logo -->
    <a href="#home" class="logo-area">
      <img src={logoImg.src} alt="Ogres Games Logo" class="logo-image" />
      <span class="logo-text glow-text-purple">OGRES GAMES</span>
    </a>

    <!-- Hamburger menu for mobile -->
    <button class="mobile-menu-toggle" id="mobile-toggle" aria-label="Toggle Navigation Menu">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>

    <!-- Nav Links & Controls -->
    <nav class="nav-menu" id="nav-menu">
      <a href="#home" class="nav-link arcade-font">INICIO</a>
      <a href="#discord-quest" class="nav-link arcade-font">DISCORD</a>
      <a href="#servers" class="nav-link arcade-font">SERVIDORES</a>
      <a href="#team" class="nav-link arcade-font">EQUIPO</a>
      <a href="#donations" class="nav-link arcade-font">DONAR</a>
      
      <!-- CRT Status Indicator -->
      <div class="crt-status-indicator">
        <span class="led"></span>
        <span class="btn-text">CRT FILTER: ON</span>
      </div>
    </nav>
  </div>
</header>

<script>
  // Mobile menu toggle
  const mobileToggle = document.getElementById('mobile-toggle');
  const navMenu = document.getElementById('nav-menu');

  mobileToggle?.addEventListener('click', () => {
    mobileToggle.classList.toggle('active');
    navMenu?.classList.toggle('active');
  });

  // Close mobile menu when clicking a link
  const navLinks = document.querySelectorAll('.nav-link');
  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileToggle?.classList.remove('active');
      navMenu?.classList.remove('active');
    });
  });
</script>

<style>
  .retro-header {
    position: sticky;
    top: 0;
    z-index: 10000;
    background-color: rgba(7, 5, 14, 0.9);
    border-bottom: 3px solid var(--neon-purple);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.5), 0 0 10px var(--neon-purple-glow);
    backdrop-filter: blur(8px);
    height: 80px;
    display: flex;
    align-items: center;
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .logo-area {
    display: flex;
    align-items: center;
    text-decoration: none;
    gap: 15px;
  }

  .logo-image {
    height: 50px;
    width: auto;
    filter: drop-shadow(0 0 5px var(--neon-purple-glow));
    transition: transform 0.3s ease;
  }

  .logo-area:hover .logo-image {
    transform: rotate(5deg) scale(1.05);
  }

  .logo-text {
    font-family: var(--font-arcade);
    font-size: 1.1rem;
    font-weight: bold;
    color: #fff;
    letter-spacing: 1px;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: 30px;
  }

  .nav-link {
    color: var(--color-text-muted);
    font-size: 0.75rem;
    text-decoration: none;
    position: relative;
    padding: 8px 0;
    transition: color 0.15s ease-in-out;
  }

  .nav-link:hover, .nav-link:focus {
    color: var(--neon-cyan);
    text-shadow: 0 0 5px var(--neon-cyan-glow);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 3px;
    background-color: var(--neon-cyan);
    box-shadow: 0 0 5px var(--neon-cyan-glow);
    transition: width 0.15s ease-in-out;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  /* CRT Status Indicator Styling */
  .crt-status-indicator {
    background: #141026;
    border: 2px solid var(--neon-purple);
    border-radius: 0;
    color: #fff;
    font-family: var(--font-arcade);
    font-size: 0.65rem;
    padding: 8px 16px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 0 5px var(--neon-purple-glow);
  }

  .crt-status-indicator .led {
    width: 8px;
    height: 8px;
    background-color: var(--neon-green);
    box-shadow: 0 0 8px var(--neon-green);
    border-radius: 50%;
  }

  /* Mobile menu button styles */
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 30px;
    height: 21px;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 1001;
  }

  .mobile-menu-toggle .bar {
    width: 100%;
    height: 3px;
    background-color: var(--neon-purple);
    box-shadow: 0 0 5px var(--neon-purple-glow);
    transition: all 0.25s ease-in-out;
  }

  @media (max-width: 900px) {
    .mobile-menu-toggle {
      display: flex;
    }

    .nav-menu {
      position: fixed;
      top: 80px;
      left: -100%;
      width: 100%;
      height: calc(100vh - 80px);
      background-color: #07050e;
      border-top: 3px solid var(--neon-purple);
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 40px;
      transition: left 0.3s ease-in-out;
      padding-bottom: 80px;
      z-index: 999;
    }

    .nav-menu.active {
      left: 0;
    }

    .nav-link {
      font-size: 1.1rem;
    }

    .mobile-menu-toggle.active .bar:nth-child(1) {
      transform: translateY(9px) rotate(45deg);
      background-color: var(--neon-cyan);
      box-shadow: 0 0 5px var(--neon-cyan-glow);
    }

    .mobile-menu-toggle.active .bar:nth-child(2) {
      opacity: 0;
    }

    .mobile-menu-toggle.active .bar:nth-child(3) {
      transform: translateY(-9px) rotate(-45deg);
      background-color: var(--neon-cyan);
      box-shadow: 0 0 5px var(--neon-cyan-glow);
    }
  }
</style>
