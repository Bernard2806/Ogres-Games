---
// Footer.astro
---

<footer class="retro-footer">
  <div class="container footer-content-centered">
    
    <!-- Centered Brand Section -->
    <div class="footer-brand-section">
      <h3 class="footer-title arcade-font glow-text-purple">OGRES GAMES</h3>
      <p class="footer-tagline">Creando experiencias de juego de la vieja escuela y uniendo a entrenadores Pokémon y gamers de todo el mundo.</p>
      
      <div class="credits-insert-coin terminal-font">
        <span class="blink-text">★ INSERT COIN TO PLAY ★</span>
      </div>
    </div>
    
  </div>
  
  <div class="footer-bottom-bar arcade-font">
    <div class="container footer-bottom-container">
      <div class="copyright">© 2026 OGRES GAMES. PRESS START.</div>
      <div class="credits">
        MADE WITH 💜 BY <a href="https://bernard2806.is-a.dev/" target="_blank" rel="noopener noreferrer" class="portfolio-link">BERNARDO G. ERRAMUSPE</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .retro-footer {
    background-color: #05030a;
    border-top: 4px solid var(--neon-purple);
    padding: 60px 0 0 0;
    margin-top: 60px;
    position: relative;
    box-shadow: 0 -5px 20px rgba(0, 0, 0, 0.8), 0 0 10px var(--neon-purple-glow);
  }

  .footer-content-centered {
    display: flex;
    justify-content: center;
    text-align: center;
    margin-bottom: 50px;
  }

  /* Brand Column */
  .footer-brand-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    max-width: 600px;
  }

  .footer-title {
    font-size: 1.2rem;
    color: #fff;
    margin-bottom: 5px;
  }

  .footer-tagline {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .credits-insert-coin {
    font-size: 1.2rem;
    color: var(--neon-yellow);
    text-shadow: 0 0 5px var(--neon-yellow-glow);
    margin-top: 15px;
  }

  .blink-text {
    animation: text-blink 1s steps(2, start) infinite;
  }

  @keyframes text-blink {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 1; }
  }

  /* Bottom Copyright Bar */
  .footer-bottom-bar {
    background-color: #030206;
    border-top: 2px solid #141026;
    padding: 20px 0;
    margin-top: 40px;
  }

  .footer-bottom-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.6rem;
    color: var(--color-text-muted);
  }

  .portfolio-link {
    color: inherit;
    text-decoration: none;
    cursor: default;
  }

  .portfolio-link:hover,
  .portfolio-link:focus,
  .portfolio-link:active {
    color: inherit;
    text-decoration: none;
    outline: none;
  }

  @media (max-width: 576px) {
    .footer-bottom-container {
      flex-direction: column;
      gap: 10px;
      text-align: center;
    }
  }
</style>
