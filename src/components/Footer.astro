---
// Footer.astro
import configData from '../data/config.json';
---

<footer class="retro-footer">
  <div class="container footer-grid">
    
    <!-- Left Column: Community Call out -->
    <div class="footer-brand-section">
      <h3 class="footer-title arcade-font glow-text-purple">OGRES GAMES</h3>
      <p class="footer-tagline">Creando experiencias de juego de la vieja escuela y uniendo a entrenadores Pokémon y gamers de todo el mundo.</p>
      
      <div class="credits-insert-coin terminal-font">
        <span class="blink-text">★ INSERT COIN TO PLAY ★</span>
      </div>
    </div>
    
    <!-- Middle Column: Join Newsletter styled as terminal prompt -->
    <div class="footer-newsletter pixel-border">
      <h4 class="newsletter-title font-arcade">NEWSLETTER.EXE</h4>
      <p class="newsletter-desc">Recibe parches, alertas de torneos de Pixelmon y noticias del estudio antes que nadie.</p>
      
      <form class="retro-form" onsubmit="event.preventDefault(); alert('¡Inscrito en la base de datos de Ogres Games!');">
        <div class="input-wrapper">
          <span class="prompt-symbol terminal-font">&gt;</span>
          <input type="email" placeholder="TU_CORREO@EMAIL.COM" class="retro-input terminal-font" required />
        </div>
        <button type="submit" class="pixel-button pixel-button-cyan font-arcade newsletter-btn">
          ENVIAR
        </button>
      </form>
    </div>
    
    <!-- Right Column: Quick Links & Console Buttons -->
    <div class="footer-controls">
      <h4 class="newsletter-title font-arcade">SOCIAL DECK</h4>
      <div class="control-deck">
        <div class="dpad">
          <div class="dpad-btn up" title="Subir"></div>
          <div class="dpad-btn left" title="Anterior"></div>
          <div class="dpad-btn right" title="Siguiente"></div>
          <div class="dpad-btn down" title="Bajar"></div>
          <div class="dpad-center"></div>
        </div>
        
        <div class="gameboy-buttons">
          <a href={configData.discordUrl} target="_blank" rel="noopener noreferrer" class="gameboy-btn btn-a" title="Discord">
            <span class="label font-arcade">A</span>
            <span class="tooltip font-arcade">DISCORD</span>
          </a>
          <a href="https://github.com/Bernard2806" target="_blank" rel="noopener noreferrer" class="gameboy-btn btn-b" title="GitHub">
            <span class="label font-arcade">B</span>
            <span class="tooltip font-arcade">GITHUB</span>
          </a>
        </div>
      </div>
    </div>
    
  </div>
  
  <div class="footer-bottom-bar font-arcade">
    <div class="container footer-bottom-container">
      <div class="copyright">© 2026 OGRES GAMES. PRESS START.</div>
      <div class="credits">MADE WITH 💜 AND ASTRO</div>
    </div>
  </div>
</footer>

<style>
  .retro-footer {
    background-color: #05030a;
    border-top: 4px solid var(--neon-purple);
    padding: 60px 0 0 0;
    margin-top: 60px;
    position: relative;
    box-shadow: 0 -5px 20px rgba(0, 0, 0, 0.8), 0 0 10px var(--neon-purple-glow);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 40px;
    margin-bottom: 50px;
  }

  /* Brand Column */
  .footer-brand-section {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 20px;
  }

  .footer-title {
    font-size: 1.2rem;
    color: #fff;
    margin-bottom: 5px;
  }

  .footer-tagline {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .credits-insert-coin {
    font-size: 1.2rem;
    color: var(--neon-yellow);
    text-shadow: 0 0 5px var(--neon-yellow-glow);
    margin-top: 15px;
  }

  .blink-text {
    animation: text-blink 1s steps(2, start) infinite;
  }

  @keyframes text-blink {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 1; }
  }

  /* Newsletter Column */
  .footer-newsletter {
    background-color: rgba(16, 12, 30, 0.6);
    border-color: #231c3c;
    padding: 25px;
    border-radius: 4px;
  }

  .newsletter-title {
    font-size: 0.75rem;
    color: var(--neon-cyan);
    text-shadow: 0 0 5px var(--neon-cyan-glow);
    margin-bottom: 15px;
    letter-spacing: 1px;
  }

  .newsletter-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 20px;
    line-height: 1.5;
  }

  .retro-form {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .input-wrapper {
    position: relative;
    background: #090612;
    border: 2px solid #231c3c;
    display: flex;
    align-items: center;
    padding: 5px 12px;
  }

  .input-wrapper:focus-within {
    border-color: var(--neon-cyan);
    box-shadow: 0 0 8px var(--neon-cyan-glow);
  }

  .prompt-symbol {
    color: var(--neon-cyan);
    text-shadow: 0 0 3px var(--neon-cyan-glow);
    font-size: 1.2rem;
    margin-right: 10px;
  }

  .retro-input {
    background: transparent;
    border: none;
    outline: none;
    color: #fff;
    font-size: 1.1rem;
    width: 100%;
  }

  .retro-input::placeholder {
    color: #3b3066;
  }

  .newsletter-btn {
    width: 100%;
    font-size: 0.75rem;
    padding: 12px 0;
  }

  /* Social Deck / Gameboy Controller Column */
  .footer-controls {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .control-deck {
    background: #141026;
    border: 3px solid #231c3c;
    border-radius: 12px;
    padding: 25px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: inset 0 0 15px rgba(0,0,0,0.5);
    height: 150px;
  }

  /* D-PAD representation */
  .dpad {
    position: relative;
    width: 75px;
    height: 75px;
  }

  .dpad-btn {
    position: absolute;
    background-color: #231c3c;
    border: 2px solid #3c3066;
    cursor: pointer;
  }

  .dpad-btn:active {
    background-color: var(--neon-cyan);
  }

  .dpad-btn.up {
    top: 0;
    left: 25px;
    width: 25px;
    height: 27px;
    border-bottom: none;
    border-radius: 4px 4px 0 0;
  }

  .dpad-btn.down {
    bottom: 0;
    left: 25px;
    width: 25px;
    height: 27px;
    border-top: none;
    border-radius: 0 0 4px 4px;
  }

  .dpad-btn.left {
    top: 25px;
    left: 0;
    width: 27px;
    height: 25px;
    border-right: none;
    border-radius: 4px 0 0 4px;
  }

  .dpad-btn.right {
    top: 25px;
    right: 0;
    width: 27px;
    height: 25px;
    border-left: none;
    border-radius: 0 4px 4px 0;
  }

  .dpad-center {
    position: absolute;
    top: 25px;
    left: 25px;
    width: 25px;
    height: 25px;
    background-color: #231c3c;
  }

  /* Gameboy Buttons representation */
  .gameboy-buttons {
    display: flex;
    gap: 15px;
    transform: rotate(-15deg);
  }

  .gameboy-btn {
    position: relative;
    width: 38px;
    height: 38px;
    background: radial-gradient(circle, #ff0055 40%, #a30036 100%);
    border: 2px solid #ff578f;
    border-radius: 50%;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.1s ease;
  }

  .gameboy-btn:active {
    transform: scale(0.9) translateY(2px);
    box-shadow: 0 2px 3px rgba(0, 0, 0, 0.6);
  }

  .gameboy-btn .label {
    font-size: 0.55rem;
    color: rgba(255, 255, 255, 0.8);
    position: absolute;
    bottom: -18px;
    text-shadow: 1px 1px 1px rgba(0,0,0,0.8);
  }

  .gameboy-btn .tooltip {
    position: absolute;
    top: -30px;
    background-color: #000;
    border: 1px solid var(--neon-cyan);
    color: var(--neon-cyan);
    padding: 3px 6px;
    font-size: 0.45rem;
    border-radius: 2px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
    white-space: nowrap;
    z-index: 10;
  }

  .gameboy-btn:hover .tooltip {
    opacity: 1;
  }

  /* Bottom Copyright Bar */
  .footer-bottom-bar {
    background-color: #030206;
    border-top: 2px solid #141026;
    padding: 20px 0;
    margin-top: 40px;
  }

  .footer-bottom-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.6rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 992px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }

  @media (max-width: 576px) {
    .footer-bottom-container {
      flex-direction: column;
      gap: 10px;
      text-align: center;
    }
  }
</style>
