---
// Shop.astro
import shopItems from '../data/shop.json';
---

<section id="shop" class="shop-section">
  <div class="container">
    <h2 class="section-title">TIENDA ITEM SHOP</h2>
    <p class="section-desc">¡Todo sea por el server! Apoya el mantenimiento de nuestros servidores Pokémon y el desarrollo de juegos independientes de Ogres Games.</p>
    
    <!-- Merchant NPC Speech Bubble -->
    <div class="merchant-speech pixel-border">
      <div class="npc-avatar">🧙‍♂️</div>
      <div class="speech-bubble">
        <p class="terminal-font glow-text-green">&gt; ¡BIENVENIDO, ENTRENADOR! ¿BUSCAS ALGO DE PODER EXTRA PARA TU AVENTURA O QUIERES APOYAR EL PANTANO? ELIGE TU ITEM...</p>
      </div>
    </div>
    
    <!-- Vending Machine Grid -->
    <div class="vending-machine-grid">
      {shopItems.map((item) => (
        <div class="shop-card pixel-border" style={`--item-glow: ${item.glowColor}`}>
          
          <!-- Card Header / Tag -->
          <div class="card-header-tag">
            <span class="tag tag-pink font-arcade">{item.tag}</span>
          </div>
          
          <!-- Floating Icon Area -->
          <div class="item-visual-area">
            <div class="item-icon-glow"></div>
            <span class="item-3d-icon">{item.icon}</span>
          </div>
          
          <!-- Product Name -->
          <h3 class="item-name arcade-font">{item.name}</h3>
          
          <div class="item-divider"></div>
          
          <!-- Product Benefits -->
          <ul class="item-benefits-list">
            {item.benefits.map(benefit => (
              <li class="benefit-item">
                <span class="bullet-arrow">▶</span> {benefit}
              </li>
            ))}
          </ul>
          
          <div class="item-divider"></div>
          
          <!-- Footer Price and Action -->
          <div class="item-checkout-block">
            <div class="item-price terminal-font">
              <span class="gold-symbol">🪙</span> 
              <span class="price-val">{item.price}</span> 
              <span class="price-currency">{item.currency}</span>
            </div>
            
            <a 
              href={item.checkoutUrl} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="pixel-button pixel-button-green checkout-btn font-arcade"
            >
              COMPRAR
            </a>
          </div>
          
        </div>
      ))}
    </div>
    
    <!-- Donation Meter/Server Status Support -->
    <div class="support-meter-panel pixel-border">
      <div class="meter-header">
        <h4 class="meter-title font-arcade">SERVER_FUNDING.EXE (META MENSUAL)</h4>
        <span class="meter-percent font-arcade text-green blink-text">78% FINANCIADO</span>
      </div>
      <div class="meter-bar-track">
        <div class="meter-bar-fill" style="width: 78%">
          <div class="meter-bar-glow"></div>
        </div>
      </div>
      <p class="meter-info terminal-font">&gt; Costo de servidores y hosting: $78.00 / $100.00 USD. ¡Ayúdanos a llegar al 100% para expandir slots y agregar nuevos mods de Pokémon!</p>
    </div>
    
  </div>
</section>

<style>
  .shop-section {
    padding: 100px 0;
    background-color: #07050e;
    border-top: 3px solid #141026;
  }

  .section-desc {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-top: -30px;
    margin-bottom: 40px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Merchant NPC speech styling */
  .merchant-speech {
    background-color: rgba(16, 12, 30, 0.7);
    border-color: #231c3c;
    padding: 20px;
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 50px;
    border-radius: 4px;
  }

  .npc-avatar {
    font-size: 2.8rem;
    animation: npc-idle 1.5s ease infinite alternate;
  }

  @keyframes npc-idle {
    0% { transform: translateY(0) scale(1); }
    100% { transform: translateY(-5px) scale(1.05); }
  }

  .speech-bubble {
    flex-grow: 1;
    position: relative;
  }

  .speech-bubble p {
    font-size: 1.15rem;
    line-height: 1.5;
  }

  /* Vending Grid */
  .vending-machine-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 35px;
    margin-bottom: 50px;
  }

  .shop-card {
    background: rgba(16, 12, 30, 0.9);
    border-color: #231c3c;
    padding: 30px 20px 25px 20px;
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
    height: 100%;
  }

  .shop-card:hover {
    transform: translateY(-8px);
    border-color: var(--item-glow);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5), 0 0 20px var(--item-glow);
  }

  .card-header-tag {
    position: absolute;
    top: 15px;
    right: 15px;
  }

  .card-header-tag .tag {
    font-size: 0.55rem;
    padding: 3px 6px;
  }

  /* Item Icon Area */
  .item-visual-area {
    height: 110px;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 15px;
  }

  .item-3d-icon {
    font-size: 3.8rem;
    z-index: 2;
    animation: icon-float 3s ease-in-out infinite;
  }

  @keyframes icon-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-8px) rotate(5deg); }
  }

  .item-icon-glow {
    position: absolute;
    width: 80px;
    height: 80px;
    background: radial-gradient(circle, var(--item-glow) 0%, transparent 70%);
    opacity: 0.35;
    z-index: 1;
    transition: opacity 0.3s ease;
  }

  .shop-card:hover .item-icon-glow {
    opacity: 0.7;
  }

  .item-name {
    font-size: 0.9rem;
    color: #fff;
    text-align: center;
    margin-bottom: 15px;
    line-height: 1.4;
  }

  .item-divider {
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, #231c3c 50%, transparent 100%);
    margin: 10px 0;
    width: 100%;
  }

  /* Benefits List */
  .item-benefits-list {
    list-style: none;
    padding: 10px 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-grow: 1;
  }

  .benefit-item {
    font-size: 0.85rem;
    line-height: 1.4;
    color: var(--color-text-muted);
    display: flex;
    gap: 8px;
  }

  .bullet-arrow {
    color: var(--item-glow);
    font-size: 0.7rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* Checkout block */
  .item-checkout-block {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 15px;
    gap: 10px;
  }

  .item-price {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .gold-symbol {
    font-size: 1.3rem;
  }

  .price-val {
    font-size: 1.4rem;
    color: var(--neon-yellow);
    text-shadow: 0 0 5px var(--neon-yellow-glow);
    font-weight: bold;
  }

  .price-currency {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    align-self: flex-end;
    margin-bottom: 3px;
  }

  .checkout-btn {
    font-size: 0.7rem;
    padding: 12px 18px;
    flex-shrink: 0;
  }

  /* Support Funding Meter */
  .support-meter-panel {
    background-color: rgba(16, 12, 30, 0.5);
    border-color: #231c3c;
    padding: 30px;
    margin-top: 30px;
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .meter-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .meter-title {
    font-size: 0.75rem;
    color: #fff;
  }

  .meter-percent {
    font-size: 0.75rem;
    color: var(--neon-green);
    text-shadow: 0 0 5px var(--neon-green-glow);
  }

  .meter-bar-track {
    height: 20px;
    background-color: #0d0a1c;
    border: 2px solid #231c3c;
    position: relative;
    padding: 2px;
  }

  .meter-bar-fill {
    height: 100%;
    background-color: var(--neon-green);
    box-shadow: 0 0 10px var(--neon-green-glow);
    position: relative;
    transition: width 1s ease-in-out;
  }

  .meter-bar-glow {
    position: absolute;
    top: 0;
    bottom: 0;
    right: 0;
    width: 15px;
    background-color: #fff;
    box-shadow: 0 0 15px #fff;
    opacity: 0.8;
  }

  .meter-info {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .merchant-speech {
      flex-direction: column;
      text-align: center;
    }
    
    .item-checkout-block {
      flex-direction: column;
      gap: 15px;
      align-items: center;
    }
    
    .checkout-btn {
      width: 100%;
      text-align: center;
    }
    
    .meter-header {
      flex-direction: column;
      gap: 10px;
      align-items: flex-start;
    }
  }
</style>
