---
// Team.astro
import teamData from '../data/team.json';
---

<section id="team" class="team-section">
  <div class="container">
    <h2 class="section-title">EL EQUIPO</h2>
    <p class="section-desc">Conoce a los desarrolladores, artistas y bardos detrás de Ogres Games.</p>
    
    <div class={`character-select-container ${teamData.length === 1 ? 'single-member' : ''}`}>
      
      <!-- Character Selection Grid (Left Side) -->
      {teamData.length > 1 && (
        <div class="char-grid-wrapper">
          <h3 class="char-grid-title arcade-font">AVATARS SELECT:</h3>
          <div class="character-grid" id="char-grid">
            {teamData.map((member, idx) => (
              <button 
                class={`char-portrait pixel-border ${idx === 0 ? 'selected' : ''}`}
                data-member-id={member.id}
                aria-label={`Select ${member.name}`}
              >
                <div class="portrait-container">
                  <img src={member.avatarUrl} alt={member.name} class="char-avatar" />
                </div>
                <div class="char-grid-name terminal-font">{member.name}</div>
                <div class="selection-indicator"></div>
              </button>
            ))}
          </div>
        </div>
      )}
      
      <!-- RPG Character Stat Card (Right Side) -->
      <div class="character-card-panel pixel-border" id="character-panel">
        {teamData.map((member, idx) => (
          <div 
            class={`char-full-details ${idx === 0 ? 'active' : ''}`} 
            id={`details-${member.id}`}
          >
            <!-- Header Info -->
            <div class="char-profile-header">
              <div class="char-profile-avatar-frame">
                <img src={member.avatarUrl} alt={member.name} class="char-large-avatar" />
                <span class="char-level arcade-font">LV.{member.level}</span>
              </div>
              
              <div class="char-title-block">
                <h3 class="char-name arcade-font glow-text-purple">{member.name}</h3>
                <span class="char-class tag tag-purple">{member.class}</span>
              </div>
            </div>
            
            <div class="divider-line"></div>
            
            <!-- RPG Stats Section -->
            <div class="char-rpg-stats">
              <h4 class="stats-label arcade-font">STATS:</h4>
              <div class="stats-bars">
                
                {Object.entries(member.stats).map(([statName, val]) => (
                  <div class="stat-row">
                    <span class="stat-name terminal-font">{statName.toUpperCase()}</span>
                    <div class="stat-bar-container">
                      <div 
                        class={`stat-bar-fill ${statName === 'HP' ? 'bg-red' : statName === 'MP' ? 'bg-blue' : 'bg-green'}`} 
                        style={`width: ${val}%`}
                      ></div>
                    </div>
                    <span class="stat-val terminal-font">{val}/100</span>
                  </div>
                ))}
                
              </div>
            </div>
            
            <div class="divider-line"></div>
            
            <!-- Character Description -->
            <div class="char-lore">
              <h4 class="stats-label arcade-font">DESCRIPCIÓN:</h4>
              <p class="lore-text">{member.description}</p>
            </div>
            
            <div class="divider-line"></div>
            
            <!-- Social buttons -->
            <div class="char-socials">
              <h4 class="stats-label arcade-font">CONTACTO:</h4>
              <div class="social-icons">
                {member.socials.github && (
                  <a href={member.socials.github} target="_blank" rel="noopener noreferrer" class="social-btn social-btn--github" title="GitHub">
                    <svg class="social-icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                    <span>GitHub</span>
                  </a>
                )}
                {member.socials.discord && (
                  <button class="social-btn social-btn--discord copy-discord-btn" data-discord={member.socials.discord} title="Copiar tag de Discord">
                    <svg class="social-icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z"/></svg>
                    <span class="discord-tag-text">{member.socials.discord}</span>
                  </button>
                )}
                {member.socials.steam && (
                  <a href={member.socials.steam} target="_blank" rel="noopener noreferrer" class="social-btn social-btn--steam" title="Steam">
                    <svg class="social-icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.605 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.5 1.009 2.455-.397.957-1.497 1.41-2.454 1.012H7.54zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.663 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.253 0-2.265-1.014-2.265-2.265z"/></svg>
                    <span>Steam</span>
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
      
    </div>
  </div>
</section>

<script>
  // Character Select Logic
  const portraits = document.querySelectorAll('.char-portrait');
  const detailsPanels = document.querySelectorAll('.char-full-details');
  
  portraits.forEach(portrait => {
    // We trigger character switch on hover OR click for fluid experience
    const triggerSelection = () => {
      const memberId = portrait.getAttribute('data-member-id');
      
      // De-select all portraits
      portraits.forEach(p => p.classList.remove('selected'));
      
      // Select clicked portrait
      portrait.classList.add('selected');
      
      // Hide all details panels
      detailsPanels.forEach(panel => panel.classList.remove('active'));
      
      // Show corresponding details panel
      const targetPanel = document.getElementById(`details-${memberId}`);
      if (targetPanel) {
        targetPanel.classList.add('active');
      }
    };

    portrait.addEventListener('click', triggerSelection);
    portrait.addEventListener('mouseenter', triggerSelection);
  });

  // Copy Discord tag functionality
  const copyDiscordBtns = document.querySelectorAll('.copy-discord-btn');
  copyDiscordBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation(); // Avoid triggering parent switch
      const tag = btn.getAttribute('data-discord');
      if (tag) {
        navigator.clipboard.writeText(tag).then(() => {
          const tagSpan = btn.querySelector('.discord-tag-text');
          if (tagSpan) {
            const originalText = tagSpan.textContent;
            tagSpan.textContent = "¡COPIADO!";
            setTimeout(() => {
              tagSpan.textContent = originalText;
            }, 2000);
          }
        });
      }
    });
  });
</script>

<style>
  .team-section {
    padding: 100px 0;
    background-color: rgba(7, 5, 14, 0.4);
    border-top: 3px solid #141026;
  }

  .character-select-container {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 40px;
    margin-top: 40px;
  }

  .character-select-container.single-member {
    grid-template-columns: 1fr;
    max-width: 650px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Grid Panel (Avatars) */
  .char-grid-wrapper {
    background: rgba(16, 12, 30, 0.5);
    border: 3px solid #231c3c;
    padding: 25px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .char-grid-title {
    font-size: 0.7rem;
    color: var(--neon-cyan);
    text-shadow: 0 0 5px var(--neon-cyan-glow);
    border-bottom: 2px dashed #231c3c;
    padding-bottom: 12px;
  }

  .character-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 20px;
  }

  .char-portrait {
    background: #141026;
    border-color: #322852;
    padding: 15px 10px;
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    position: relative;
    transition: all 0.2s ease;
    outline: none;
  }

  .portrait-container {
    width: 75px;
    height: 75px;
    background: #090612;
    border: 2px solid #231c3c;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .char-avatar {
    width: 90%;
    height: auto;
    image-rendering: pixelated;
    transition: transform 0.2s ease;
  }

  .char-grid-name {
    font-size: 1rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  /* Selected Portrait state */
  .char-portrait.selected {
    border-color: var(--neon-purple);
    box-shadow: 0 0 15px var(--neon-purple-glow);
    background: #1e1836;
  }

  .char-portrait.selected .portrait-container {
    border-color: var(--neon-purple);
  }

  .char-portrait.selected .char-avatar {
    transform: scale(1.08);
  }

  .char-portrait.selected .char-grid-name {
    color: #fff;
    text-shadow: 0 0 5px var(--neon-purple-glow);
  }

  .selection-indicator {
    display: none;
    position: absolute;
    top: 5px;
    right: 5px;
    width: 6px;
    height: 6px;
    background-color: var(--neon-purple);
    box-shadow: 0 0 5px var(--neon-purple);
  }

  .char-portrait.selected .selection-indicator {
    display: block;
  }

  /* RPG Card Display (Right Panel) */
  .character-card-panel {
    background: var(--color-panel-bg);
    border-color: #231c3c;
    padding: 35px;
    min-height: 480px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .char-full-details {
    display: none;
    flex-direction: column;
    gap: 20px;
  }

  .char-full-details.active {
    display: flex;
    animation: panel-fade-in 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  @keyframes panel-fade-in {
    from { opacity: 0; transform: scale(0.97) translateX(10px); }
    to { opacity: 1; transform: scale(1) translateX(0); }
  }

  .char-profile-header {
    display: flex;
    align-items: center;
    gap: 25px;
  }

  .char-profile-avatar-frame {
    position: relative;
    width: 100px;
    height: 100px;
    background: #090612;
    border: 3px solid var(--neon-purple);
    box-shadow: 0 0 10px var(--neon-purple-glow);
    padding: 5px;
  }

  .char-large-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    image-rendering: pixelated;
  }

  .char-level {
    position: absolute;
    bottom: -8px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--neon-purple);
    color: #fff;
    font-size: 0.55rem;
    padding: 2px 6px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.5);
  }

  .char-title-block {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .char-name {
    font-size: 1.4rem;
    color: #fff;
    letter-spacing: 1px;
  }

  .divider-line {
    height: 2px;
    background: linear-gradient(90deg, #231c3c 0%, rgba(35, 28, 60, 0) 100%);
  }

  .stats-label {
    font-size: 0.65rem;
    color: var(--neon-cyan);
    margin-bottom: 12px;
    letter-spacing: 1px;
  }

  .stats-bars {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .stat-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 15px;
  }

  .stat-name {
    width: 70px;
    font-size: 1.05rem;
    color: var(--color-text-muted);
  }

  .stat-bar-container {
    flex-grow: 1;
    height: 12px;
    background-color: #0d0a1c;
    border: 1px solid #231c3c;
    border-radius: 0;
    overflow: hidden;
  }

  .stat-bar-fill {
    height: 100%;
    transition: width 0.5s ease-out;
  }

  .bg-red {
    background-color: #ff0055;
    box-shadow: 0 0 8px rgba(255, 0, 85, 0.6);
  }

  .bg-blue {
    background-color: var(--neon-cyan);
    box-shadow: 0 0 8px var(--neon-cyan-glow);
  }

  .bg-green {
    background-color: var(--neon-green);
    box-shadow: 0 0 8px var(--neon-green-glow);
  }

  .stat-val {
    width: 60px;
    text-align: right;
    font-size: 1.05rem;
  }

  /* Lore text */
  .lore-text {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text);
  }

  /* Social Links in Stat Card */
  .social-icons {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border: 2px solid;
    background: rgba(12, 9, 20, 0.6);
    font-family: inherit;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: all 0.25s ease;
    text-decoration: none;
    border-radius: 2px;
  }

  .social-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  /* GitHub - white/grey */
  .social-btn--github {
    color: #e6edf3;
    border-color: #3d444d;
  }
  .social-btn--github:hover {
    background: rgba(110, 118, 129, 0.2);
    border-color: #e6edf3;
    box-shadow: 0 0 12px rgba(230, 237, 243, 0.25);
  }

  /* Discord - blurple */
  .social-btn--discord {
    color: #5865F2;
    border-color: #4752c4;
  }
  .social-btn--discord:hover {
    background: rgba(88, 101, 242, 0.15);
    border-color: #5865F2;
    box-shadow: 0 0 12px rgba(88, 101, 242, 0.35);
  }

  /* Steam - dark blue */
  .social-btn--steam {
    color: #66c0f4;
    border-color: #2a475e;
  }
  .social-btn--steam:hover {
    background: rgba(102, 192, 244, 0.12);
    border-color: #66c0f4;
    box-shadow: 0 0 12px rgba(102, 192, 244, 0.3);
  }

  @media (max-width: 900px) {
    .character-select-container {
      grid-template-columns: 1fr;
    }
    
    .character-card-panel {
      min-height: auto;
    }
  }

  @media (max-width: 576px) {
    .character-grid {
      grid-template-columns: 1fr 1fr;
    }
    .char-profile-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 15px;
    }
    .social-icons {
      flex-direction: column;
      width: 100%;
    }
    .social-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
