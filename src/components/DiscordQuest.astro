---
// DiscordQuest.astro
import configData from '../data/config.json';
---

<section id="discord-quest" class="discord-quest-section">
  <div class="container">
    
    <div class="discord-card pixel-border">
      <div class="discord-header arcade-font">
        <span class="led glow-led"></span>
        <span class="title-text glow-text-purple">NUESTRO DISCORD OFICIAL</span>
        <span class="led glow-led"></span>
      </div>
      
      <div class="discord-body">
        <p class="discord-description">
          ¡Únete a la central de operaciones de Ogres Games! Entra a nuestro servidor de Discord para charlar con otros entrenadores y jugadores, coordinar batallas en nuestros servidores de Minecraft Pokémon, participar en sorteos exclusivos y recibir soporte directo de los administradores.
        </p>
        
        <div class="discord-cta">
          <a 
            href={configData.discordUrl} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="pixel-button pixel-button-pink discord-btn arcade-font glow-btn"
          >
            🎮 UNIRSE AL DISCORD OFICIAL
          </a>
        </div>
      </div>
    </div>
    
  </div>
</section>

<style>
  .discord-quest-section {
    padding: 80px 0;
    background-color: #07050e;
    position: relative;
    overflow: hidden;
  }

  .discord-card {
    max-width: 700px;
    margin: 0 auto;
    background-color: rgba(16, 12, 30, 0.9);
    border-color: var(--neon-purple);
    box-shadow: 0 0 25px rgba(188, 19, 254, 0.35);
    border-radius: 4px;
    padding: 35px;
    text-align: center;
  }

  .discord-header {
    background-color: #0c0918;
    border-bottom: 2px dashed var(--neon-purple);
    padding: 15px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 15px;
    margin-bottom: 30px;
  }

  .title-text {
    font-size: 0.95rem;
    letter-spacing: 2px;
  }

  .led {
    width: 8px;
    height: 8px;
    background-color: var(--neon-purple);
    border-radius: 50%;
  }

  .glow-led {
    box-shadow: 0 0 10px var(--neon-purple), 0 0 3px var(--neon-purple);
    animation: led-glow-pulse 1s infinite alternate;
  }

  @keyframes led-glow-pulse {
    0% { opacity: 0.4; }
    100% { opacity: 1; }
  }

  .discord-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 30px;
  }

  .discord-description {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 600px;
  }

  .discord-cta {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .discord-btn {
    font-size: 0.85rem;
    padding: 16px 32px;
    width: 100%;
    max-width: 480px;
    border-color: var(--neon-pink);
    color: var(--neon-pink);
    box-shadow: 0 0 10px var(--neon-pink-glow);
    text-align: center;
    transition: all 0.2s ease-in-out;
  }

  .discord-btn:hover {
    background-color: var(--neon-pink);
    color: #07050e;
    box-shadow: 0 0 25px var(--neon-pink), 0 0 5px var(--neon-pink);
    transform: translateY(-2px);
  }

  @media (max-width: 576px) {
    .discord-card {
      padding: 25px 20px;
    }
    
    .title-text {
      font-size: 0.75rem;
      letter-spacing: 1px;
    }
  }
</style>
